# Flask
FLASK_SECRET_KEY=change-me
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=0

# Detection backend: auto | onnx | pt
WASTEAI_BACKEND=auto
WASTEAI_CONFIDENCE=0.6

# Robotic arm (Raspberry Pi -> Arduino)
WASTEAI_ARM_PORT=/dev/ttyUSB0
WASTEAI_ARM_BAUD=9600
WASTEAI_ARM_MOCK=true
WASTEAI_ARM_ACK_TIMEOUT=4.0
WASTEAI_ARM_QUEUE_MAXSIZE=16

# Camera mode: auto | opencv | picamera2
# Pour une Raspberry Pi Camera, picamera2 est le choix le plus stable.
WASTEAI_CAMERA_MODE=picamera2
WASTEAI_CAMERA_INDEX=0
WASTEAI_CAMERA_WIDTH=640
WASTEAI_CAMERA_HEIGHT=480
WASTEAI_CAMERA_LOCK_AWB=1
WASTEAI_CAMERA_LOCK_EXPOSURE=0
WASTEAI_CAMERA_AWB_SETTLE_FRAMES=20
WASTEAI_DETECTION_MIN_BOX_AREA_RATIO=0.01
WASTEAI_DETECTION_MAX_BOX_AREA_RATIO=0.995
WASTEAI_DETECTION_LARGE_EDGE_BOX_AREA_RATIO=0.999
WASTEAI_DETECTION_LARGE_EDGE_BOX_MIN_TOUCHES=4
WASTEAI_ONNX_THREADS=4
WASTEAI_STREAM_CONFIRM_HITS=2
WASTEAI_STREAM_FAST_CONFIRM_CONFIDENCE=0.90
WASTEAI_STREAM_TRACK_MAX_MISSES=2
WASTEAI_STREAM_TRACK_IOU_THRESHOLD=0.35
# Calibration fixe optionnelle.
# A n'utiliser qu'apres une vraie mesure sur scene neutre; sinon elle peut fausser
# les couleurs et la detection IA.
# WASTEAI_CAMERA_RED_GAIN=1.50
# WASTEAI_CAMERA_BLUE_GAIN=1.60
# WASTEAI_CAMERA_EXPOSURE_TIME=66663
# WASTEAI_CAMERA_ANALOGUE_GAIN=8.00
WASTEAI_STREAM_DETECT_EVERY_N_FRAMES=1
WASTEAI_STREAM_JPEG_QUALITY=75
